---
import type { HTMLAttributes } from 'astro/types'

export type ContainerSize = 'full' | 'wide' | 'content' | 'narrow'
export type ContainerTag = 'div' | 'section' | 'main' | 'article' | 'header' | 'footer' | 'nav'

type Props = {
  as?: ContainerTag
  size?: ContainerSize
  class?: string
} & HTMLAttributes<'div'>

const { as = 'div', size = 'wide', class: className, ...attrs } = Astro.props as Props

const Tag = as
const classes = [
  'rs-container',
  size === 'full' ? 'rs-container--full-width' : undefined,
  size === 'wide' ? 'rs-container--wide' : undefined,
  size === 'content' ? 'rs-container--content' : undefined,
  size === 'narrow' ? 'rs-container--narrow' : undefined,
  className,
]
---

<Tag {...attrs} class:list={classes}>
  <slot />
</Tag>

<style is:global lang="scss">
  @use '../styles/mixins' as *;

  .rs-container {
    container-type: inline-size;
    container-name: rs-component;
    --rs-container-width: var(--rs-container-width-wide, 1200px);
    --rs-container-gutter-left: max(env(safe-area-inset-left), var(--rs-container-gutter, 16px));
    --rs-container-gutter-right: max(env(safe-area-inset-right), var(--rs-container-gutter, 16px));
    --rs-container-gutters: calc(
      var(--rs-container-gutter-left, max(env(safe-area-inset-left), var(--rs-container-gutter, 16px))) +
        var(--rs-container-gutter-right, max(env(safe-area-inset-right), var(--rs-container-gutter, 16px)))
    );
    margin-inline: auto;
    max-width: calc(var(--rs-container-width, 1200px) + var(--rs-container-gutters, 32px));
    padding-inline: var(--rs-container-gutter-left, 16px) var(--rs-container-gutter-right, 16px);
    width: 100%;

    &--full-width {
      --rs-container-width: 100%;
      padding-inline: 0;
    }

    &--content {
      --rs-container-width: var(--rs-container-width-content-sm, 600px);

      @include media-breakpoint-up(lg) {
        --rs-container-width: var(--rs-container-width-content-lg, 800px);
      }
    }

    &--narrow {
      @include media-breakpoint-up(lg) {
        --rs-container-width: var(--rs-container-width-narrow-lg, 1000px);
      }
    }

    &--wide {
      --rs-container-width: var(--rs-container-width-wide, 1200px);
    }
  }
</style>
