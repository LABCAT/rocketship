---
import type { HTMLAttributes } from 'astro/types'

export type LinkVariant = 'default' | 'muted'
export type LinkSize = 'auto' | 'small' | 'medium' | 'large'

type Props = {
  href: string
  variant?: LinkVariant
  size?: LinkSize
  disabled?: boolean
  class?: string
} & HTMLAttributes<'a'>

const { href, variant = 'default', size = 'medium', disabled = false, class: className, ...attrs } =
  Astro.props as Props

const classes = [
  'rs-link',
  variant === 'muted' ? 'rs-link--muted' : undefined,
  size === 'auto' ? 'rs-link--auto-size' : `rs-link--${size}`,
  className,
]
---

<a
  {...attrs}
  aria-disabled={disabled || undefined}
  class:list={classes}
  href={disabled ? undefined : href}
  role={disabled ? 'link' : undefined}
  tabindex={disabled ? -1 : undefined}
>
  <slot />
</a>
