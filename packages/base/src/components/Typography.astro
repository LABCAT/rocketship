---
import type { HTMLAttributes } from 'astro/types'

type Props = {
  as?: 'div' | 'section' | 'article'
  html?: string
  class?: string
} & HTMLAttributes<'div'>

const { as = 'div', html, class: className, ...attrs } = Astro.props as Props
const Tag = as
---

{
  html ? (
    <Tag {...attrs} class:list={['rs-typography', className]} set:html={html} />
  ) : (
    <Tag {...attrs} class:list={['rs-typography', className]}>
      <slot />
    </Tag>
  )
}

<style is:global lang="scss">
  @import '../styles/mixins';

  .rs-typography {
    h1 {
      @include typography-h1;
    }

    h2 {
      @include typography-h2;
    }

    h3 {
      @include typography-h3;
    }

    h4 {
      @include typography-h4;
    }

    h5 {
      @include typography-h5;
    }

    h6 {
      @include typography-h6;
    }

    p {
      @include typography-p;
    }

    .intro-text {
      @include typography-intro;
    }

    i,
    em {
      @include typography-em;
    }

    b,
    strong {
      @include typography-strong;
    }

    hr {
      @include typography-hr;
    }

    li {
      @include typography-li;
    }

    ul {
      @include typography-ul;
    }

    ol {
      @include typography-ol;
    }

    > :first-child {
      margin-top: 0;
    }

    > :last-child {
      margin-bottom: 0;
    }
  }
</style>
