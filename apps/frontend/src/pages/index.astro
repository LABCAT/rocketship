---
const configuredBackend = import.meta.env.PUBLIC_PAYLOAD_URL || 'http://localhost:3000'

const backendUrl = (() => {
  try {
    return new URL(configuredBackend)
  } catch {
    return new URL('http://localhost:3000')
  }
})()

const adminUrl = new URL('/admin', backendUrl).toString()
const apiUrl = new URL('/api', backendUrl).toString()
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Rocketship Frontend</title>
    <style>
      :root {
        color-scheme: light dark;
        --bg: radial-gradient(circle at 10% 20%, #7f5af0 0 20%, transparent 30%),
          radial-gradient(circle at 90% 10%, #2cb67d 0 15%, transparent 30%),
          radial-gradient(circle at 30% 90%, #ef4565 0 18%, transparent 32%), #0f172a;
        --card: rgba(255, 255, 255, 0.08);
        --border: rgba(255, 255, 255, 0.2);
        --text: #e2e8f0;
        --muted: #94a3b8;
        --accent: #7f5af0;
        --link: #2cb67d;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: var(--text);
        display: grid;
        place-items: center;
        padding: 2rem;
      }

      main {
        width: min(960px, 100%);
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 2.5rem;
        backdrop-filter: blur(12px);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
      }

      h1 {
        font-size: clamp(2rem, 4vw, 3rem);
        margin: 0 0 0.75rem;
      }

      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--muted);
        margin: 0 0 0.35rem;
      }

      p {
        margin: 0 0 1.5rem;
        color: var(--muted);
        line-height: 1.6;
      }

      .actions {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        margin: 2rem 0;
      }

      a.button {
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.95rem 1.25rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: linear-gradient(135deg, rgba(127, 90, 240, 0.2), rgba(44, 182, 125, 0.18));
        color: white;
        font-weight: 600;
        transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
      }

      a.button:hover {
        transform: translateY(-2px);
        border-color: rgba(255, 255, 255, 0.35);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.35);
      }

      code {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid var(--border);
        padding: 0.2rem 0.5rem;
        border-radius: 8px;
        color: white;
      }

      .footer {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        font-size: 0.95rem;
        color: var(--muted);
      }

      .footer strong {
        color: var(--text);
      }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">Astro 6 · Payload CMS backend</p>
      <h1>Rocketship frontend, ready for launch.</h1>
      <p>
        This Astro site ships as the public-facing UI. Your Payload CMS backend powers data and admin tooling
        from the same monorepo.
      </p>

      <div class="actions">
        <a class="button" href={adminUrl} target="_blank" rel="noreferrer">Open Payload Admin</a>
        <a class="button" href={apiUrl} target="_blank" rel="noreferrer">Backend API</a>
        <a class="button" href="https://docs.astro.build" target="_blank" rel="noreferrer">Astro Docs</a>
        <a class="button" href="https://payloadcms.com/docs" target="_blank" rel="noreferrer">Payload Docs</a>
      </div>

      <div class="footer">
        <span>Backend target: <strong>{backendUrl.toString()}</strong></span>
        <span>Configure with <code>PUBLIC_PAYLOAD_URL</code></span>
      </div>
    </main>
  </body>
</html>
