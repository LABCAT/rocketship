{
  "name": "rocketship",
  "version": "1.0.0",
  "private": true,
  "description": "Rocketship monorepo (Payload + Astro)",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "build:backend": "pnpm --filter @rocketship/backend build",
    "build:frontend": "pnpm --filter @rocketship/frontend build",
    "build:storybook": "pnpm --filter @rocketship/frontend build-storybook",
    "deploy": "pnpm --filter @rocketship/backend deploy",
    "dev": "pnpm run dev:backend",
    "dev:backend": "pnpm --filter @rocketship/backend dev",
    "dev:all": "pnpm -r --parallel --filter @rocketship/backend --filter @rocketship/frontend dev",
    "dev:frontend": "pnpm --filter @rocketship/frontend dev",
    "dev:storybook": "pnpm --filter @rocketship/frontend storybook",
    "devsafe": "pnpm --filter @rocketship/backend devsafe",
    "generate:importmap": "pnpm --filter @rocketship/backend generate:importmap",
    "generate:types": "pnpm --filter @rocketship/backend generate:types",
    "ii": "pnpm install --ignore-workspace",
    "lint": "pnpm --filter @rocketship/backend lint",
    "payload": "pnpm --filter @rocketship/backend payload",
    "preview": "pnpm --filter @rocketship/backend preview",
    "preview:frontend": "pnpm --filter @rocketship/frontend preview",
    "setup": "node scripts/setup.mjs",
    "start": "pnpm --filter @rocketship/backend start",
    "test": "pnpm --filter @rocketship/backend test",
    "test:e2e": "pnpm --filter @rocketship/backend test:e2e",
    "test:int": "pnpm --filter @rocketship/backend test:int"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
