---
import type { HTMLAttributes } from 'astro/types'

export type ButtonVariant = 'primary' | 'secondary' | 'ghost'
export type ButtonSize = 'auto' | 'small' | 'medium' | 'large'
export type ButtonTag = 'button' | 'a'

type NativeButtonType = 'button' | 'submit' | 'reset'

type Props = {
  as?: ButtonTag
  href?: string
  variant?: ButtonVariant
  size?: ButtonSize
  disabled?: boolean
  type?: NativeButtonType
  class?: string
} & HTMLAttributes<'button'> &
  HTMLAttributes<'a'>

const {
  as = 'button',
  href,
  variant = 'primary',
  size = 'auto',
  disabled = false,
  type = 'button',
  class: className,
  ...attrs
} = Astro.props as Props

const classes = [
  'rs-button',
  `rs-button--${variant}`,
  size === 'auto' ? 'rs-button--auto-size' : `rs-button--${size}`,
  className,
]

const shouldRenderAsLink = as === 'a' || Boolean(href)
---

{
  shouldRenderAsLink ? (
    <a
      {...attrs}
      aria-disabled={disabled || undefined}
      class:list={classes}
      href={disabled ? undefined : href ?? '#'}
      role={disabled ? 'link' : undefined}
      tabindex={disabled ? -1 : undefined}
    >
      <slot />
    </a>
  ) : (
    <button {...attrs} class:list={classes} disabled={disabled} type={type}>
      <slot />
    </button>
  )
}
